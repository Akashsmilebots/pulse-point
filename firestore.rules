rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isPollHost(hostId) {
      return request.auth != null && (
        request.auth.uid == hostId ||
        (exists(/databases/$(database)/documents/hosts/$(hostId)) &&
         get(/databases/$(database)/documents/hosts/$(hostId)).data.auth_uid == request.auth.uid)
      );
    }

    match /hosts/{phone} {
      allow read, write: if true;
    }

    match /polls/{pollId} {
      // Anyone can read polls (needed for join-by-code lookup)
      allow read: if true;
      // Any authenticated user can create a poll
      allow create: if request.auth != null;
      // Only the poll host can update or delete the poll document itself
      allow update, delete: if isPollHost(resource.data.host_id);

      match /questions/{questionId} {
        // Public read so participants can fetch question details
        allow read: if true;
        // Only the host can write questions
        allow write: if isPollHost(get(/databases/$(database)/documents/polls/$(pollId)).data.host_id);
      }

      match /participants/{participantId} {
        // Public read so host/participant can look up registrations
        allow read: if true;
        // Anyone can register or update their registration (anonymous join)
        allow create, update: if true;
        // Only the host can delete participants (batch delete on reset/delete poll)
        allow delete: if isPollHost(get(/databases/$(database)/documents/polls/$(pollId)).data.host_id);
      }

      match /responses/{responseId} {
        // Public read so host can see live responses
        allow read: if true;
        // Anyone can submit a response (anonymous participant)
        allow create: if true;
        // Only the host can delete responses (batch delete on reset/delete poll)
        allow delete: if isPollHost(get(/databases/$(database)/documents/polls/$(pollId)).data.host_id);
      }

      match /leaderboard/{doc} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}